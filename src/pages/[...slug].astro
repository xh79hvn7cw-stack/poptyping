---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const fmtFullDate = (d: Date) => d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

// Pull related articles (same category, not this one, max 3)
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const related = allArticles
  .filter(a => a.id !== article.id && a.data.category === article.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

if (related.length < 3) {
  const fillers = allArticles
    .filter(a => a.id !== article.id && !related.includes(a))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3 - related.length);
  related.push(...fillers);
}

const pageTitle = `${article.data.headline.replace(/<[^>]+>/g, '')} — poptyping`;
---

<ArticleLayout title={pageTitle}>

  <!-- Headline section, above the image -->
  <header class="article-head">
    <h1 class="article-headline" set:html={article.data.headline} />
    <div class="article-pill">
      <span class="article-pill-category">{article.data.category}</span>
      <span class="article-pill-sep">·</span>
      <span class="article-pill-date">{fmtFullDate(article.data.date)}</span>
    </div>
  </header>

  <!-- Full-bleed hero image, now below headline -->
  <div class={`article-hero ${article.data.heroImage ? 'has-image' : ''}`}>
    {article.data.heroImage && (
      <img src={article.data.heroImage} alt="" />
    )}
    {article.data.heroCaption && (
      <span class="article-hero-caption">{article.data.heroCaption}</span>
    )}
  </div>

  <!-- Body -->
  <article class="article-body">
    <Content />
    <div class="article-end">END</div>
  </article>

  {related.length > 0 && (
    <section class="related">
      <h3>More <em>poptyping</em></h3>
      <div class="related-grid">
        {related.map(item => (
          <ArticleCard
            href={`/${item.id}/`}
            category={item.data.category}
            headline={item.data.headline}
            date={item.data.date}
            heroImage={item.data.heroImage}
          />
        ))}
      </div>
    </section>
  )}

</ArticleLayout>
