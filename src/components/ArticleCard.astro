---
interface Props {
  href: string;
  category: string;
  headline: string;
  date: Date;
  heroImage?: string;
  featured?: boolean;
}

const { href, category, headline, date, heroImage, featured = false } = Astro.props;
const dateString = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<a href={href} class={`card ${featured ? 'feature' : ''}`}>
  <div class={`card-image ${heroImage ? 'has-image' : ''}`}>
    {heroImage && (
      <img 
        src={heroImage} 
        alt={headline} 
        width="800" 
        height="450" 
        loading="lazy" 
      />
    )}
  </div>
  <div class="card-body">
    <span class="category">{category}</span>
    <h3>{headline}</h3>
    <time datetime={date.toISOString()}>{dateString}</time>
  </div>
</a>
