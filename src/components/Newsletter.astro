---
// Buttondown username is set as an env variable at build time, defaulting to a placeholder
const buttondownUsername = import.meta.env.PUBLIC_BUTTONDOWN_USERNAME || 'poptyping';
const formAction = `https://buttondown.com/api/emails/embed-subscribe/${buttondownUsername}`;
---

<section class="newsletter" id="newsletter">
  <div class="newsletter-inner">
    <h2>Reheated <em>goodness</em>, in your inbox.</h2>
    <form
      class="newsletter-form"
      action={formAction}
      method="post"
      target="popupwindow"
      onsubmit={`window.open('https://buttondown.com/${buttondownUsername}', 'popupwindow')`}
    >
      <p>New pieces, occasionally. No schedule. No spam.</p>
      <div class="input-group">
        <input
          type="email"
          name="email"
          placeholder="your@email.address"
          required
          aria-label="Email address"
        />
        <button type="submit">Subscribe</button>
      </div>
      <small>Unsubscribe anytime.</small>
    </form>
  </div>
</section>
